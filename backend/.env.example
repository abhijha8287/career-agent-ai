APP_ENV=local
DATABASE_URL=postgresql+psycopg://jobhunter:jobhunter@localhost:5432/jobhunter
REDIS_URL=redis://localhost:6379/0
ELASTICSEARCH_URL=http://localhost:9200
CORS_ORIGINS=["http://localhost:3000","http://localhost:3010","http://127.0.0.1:3010"]

# Public ATS job feeds are scoped per employer board/account.
GREENHOUSE_BOARDS=["openai"]
LEVER_SITES=["lever"]
ASHBY_BOARDS=["ashby"]
WORKABLE_ACCOUNTS=[]
RECRUITEE_COMPANIES=[]
PERSONIO_COMPANIES=[]
REDDIT_SUBREDDITS=["forhire","jobs","remotework","remotejobs"]
REDDIT_USER_AGENT=JobHunterAI/0.1 contact:local-dev
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
WORKDAY_CAREER_URLS=[]
SUCCESSFACTORS_CAREER_URLS=[]
ICIMS_CAREER_URLS=[]
TALEO_CAREER_URLS=[]
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
